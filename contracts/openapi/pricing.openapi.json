{
  "components": {
    "schemas": {
      "IngestProviderPriceRequest": {
        "properties": {
          "buy_price": {
            "format": "int64",
            "type": "integer"
          },
          "effective_from": {
            "format": "date-time",
            "type": "string"
          },
          "expires_at": {
            "format": "date-time",
            "type": "string"
          },
          "market_symbol": {
            "type": "string"
          },
          "provider_reference": {
            "type": "string"
          },
          "quote_per_base_unit": {
            "type": "string"
          },
          "sell_price": {
            "format": "int64",
            "type": "integer"
          }
        },
        "required": [
          "market_symbol",
          "buy_price",
          "sell_price",
          "provider_reference"
        ],
        "type": "object"
      },
      "MarketPricingStatusDetail": {
        "properties": {
          "market_symbol": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "updated_at": {
            "format": "date-time",
            "type": "string"
          },
          "updated_by": {
            "type": "string"
          }
        },
        "required": [
          "market_symbol",
          "status",
          "updated_at"
        ],
        "type": "object"
      },
      "PriceSnapshotDetail": {
        "properties": {
          "actor_id": {
            "type": "string"
          },
          "buy_price": {
            "format": "int64",
            "type": "integer"
          },
          "created_at": {
            "format": "date-time",
            "type": "string"
          },
          "effective_from": {
            "format": "date-time",
            "type": "string"
          },
          "expires_at": {
            "format": "date-time",
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "market_symbol": {
            "type": "string"
          },
          "provider_reference": {
            "type": "string"
          },
          "quote_per_base_unit": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "sell_price": {
            "format": "int64",
            "type": "integer"
          },
          "source": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "market_symbol",
          "source",
          "buy_price",
          "sell_price",
          "quote_per_base_unit",
          "effective_from",
          "created_at"
        ],
        "type": "object"
      },
      "PricingPolicyDetail": {
        "properties": {
          "base_asset_code": {
            "type": "string"
          },
          "created_at": {
            "format": "date-time",
            "type": "string"
          },
          "market_symbol": {
            "type": "string"
          },
          "quote_asset_code": {
            "type": "string"
          },
          "quote_per_base_unit": {
            "type": "string"
          },
          "updated_at": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "market_symbol",
          "base_asset_code",
          "quote_asset_code",
          "quote_per_base_unit",
          "created_at",
          "updated_at"
        ],
        "type": "object"
      },
      "SelectedPriceDetail": {
        "properties": {
          "buy_price": {
            "format": "int64",
            "type": "integer"
          },
          "effective_from": {
            "format": "date-time",
            "type": "string"
          },
          "market_status": {
            "type": "string"
          },
          "market_symbol": {
            "type": "string"
          },
          "price_snapshot_id": {
            "type": "string"
          },
          "quote_per_base_unit": {
            "type": "string"
          },
          "selected_at": {
            "format": "date-time",
            "type": "string"
          },
          "sell_price": {
            "format": "int64",
            "type": "integer"
          },
          "source": {
            "type": "string"
          }
        },
        "required": [
          "market_symbol",
          "market_status",
          "price_snapshot_id",
          "source",
          "buy_price",
          "sell_price",
          "quote_per_base_unit",
          "effective_from",
          "selected_at"
        ],
        "type": "object"
      },
      "SetManualPriceRequest": {
        "properties": {
          "actor_id": {
            "type": "string"
          },
          "buy_price": {
            "format": "int64",
            "type": "integer"
          },
          "effective_from": {
            "format": "date-time",
            "type": "string"
          },
          "expires_at": {
            "format": "date-time",
            "type": "string"
          },
          "quote_per_base_unit": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "sell_price": {
            "format": "int64",
            "type": "integer"
          }
        },
        "required": [
          "buy_price",
          "sell_price",
          "actor_id",
          "reason"
        ],
        "type": "object"
      },
      "SetMarketStatusRequest": {
        "properties": {
          "actor_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        },
        "required": [
          "status",
          "actor_id"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "bearerFormat": "JWT",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "description": "Market price sources, snapshots, validity windows, manual admin pricing, and market pricing status for existing platform markets.",
    "title": "Pricing API",
    "version": "1.0.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/health": {
      "get": {
        "operationId": "healthCheck",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "status": {
                      "example": "pong",
                      "type": "string"
                    }
                  },
                  "required": [
                    "status"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Service is healthy."
          }
        },
        "summary": "Service health check",
        "tags": [
          "Operations"
        ]
      }
    },
    "/pricing/admin/markets/{symbol}/manual-prices": {
      "post": {
        "operationId": "setManualPrice",
        "parameters": [
          {
            "description": "Platform market symbol.",
            "in": "path",
            "name": "symbol",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SetManualPriceRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PriceSnapshotDetail"
                }
              }
            },
            "description": "Manual price snapshot stored."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Invalid request body."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Market not found."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Validation error."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Unexpected error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Record a manual admin price for a market.",
        "tags": [
          "Admin"
        ]
      }
    },
    "/pricing/admin/markets/{symbol}/status": {
      "put": {
        "operationId": "setMarketPricingStatus",
        "parameters": [
          {
            "description": "Platform market symbol.",
            "in": "path",
            "name": "symbol",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SetMarketStatusRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MarketPricingStatusDetail"
                }
              }
            },
            "description": "Market pricing status updated."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Invalid request body."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Market not found."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Validation error."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Unexpected error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Set pricing status for a market.",
        "tags": [
          "Admin"
        ]
      }
    },
    "/pricing/markets/{symbol}/policy": {
      "get": {
        "operationId": "getPricingPolicy",
        "parameters": [
          {
            "description": "Platform market symbol.",
            "in": "path",
            "name": "symbol",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PricingPolicyDetail"
                }
              }
            },
            "description": "Pricing policy."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Market or policy not found."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Unexpected error."
          }
        },
        "summary": "Get canonical pricing policy for a market.",
        "tags": [
          "Catalog"
        ]
      }
    },
    "/pricing/markets/{symbol}/prices": {
      "get": {
        "operationId": "listMarketPrices",
        "parameters": [
          {
            "description": "Platform market symbol.",
            "in": "path",
            "name": "symbol",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Maximum number of snapshots to return.",
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/PriceSnapshotDetail"
                  },
                  "type": "array"
                }
              }
            },
            "description": "Price snapshots."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Market not found."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Unexpected error."
          }
        },
        "summary": "List recent price snapshots for a market.",
        "tags": [
          "Catalog"
        ]
      }
    },
    "/pricing/markets/{symbol}/selected": {
      "get": {
        "operationId": "getSelectedPrice",
        "parameters": [
          {
            "description": "Platform market symbol.",
            "in": "path",
            "name": "symbol",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SelectedPriceDetail"
                }
              }
            },
            "description": "Selected price."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Market or price not found."
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Market closed or price unavailable."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Unexpected error."
          }
        },
        "summary": "Get the currently selected valid price for a market.",
        "tags": [
          "Catalog"
        ]
      }
    },
    "/pricing/markets/{symbol}/status": {
      "get": {
        "operationId": "getMarketPricingStatus",
        "parameters": [
          {
            "description": "Platform market symbol.",
            "in": "path",
            "name": "symbol",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MarketPricingStatusDetail"
                }
              }
            },
            "description": "Market pricing status."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Market not found."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Unexpected error."
          }
        },
        "summary": "Get pricing status for a market.",
        "tags": [
          "Catalog"
        ]
      }
    },
    "/pricing/prices/provider": {
      "post": {
        "operationId": "ingestProviderPrice",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IngestProviderPriceRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PriceSnapshotDetail"
                }
              }
            },
            "description": "Provider price snapshot stored."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Invalid request body."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Market not found."
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Provider ingest not allowed for current market status."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Validation error."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Unexpected error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Ingest a provider API price snapshot.",
        "tags": [
          "Service"
        ]
      }
    },
    "/pricing/prices/{id}": {
      "get": {
        "operationId": "getPriceByID",
        "parameters": [
          {
            "description": "Price snapshot identifier.",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PriceSnapshotDetail"
                }
              }
            },
            "description": "Price snapshot."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Price snapshot not found."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Unexpected error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Get a price snapshot by identifier.",
        "tags": [
          "Service"
        ]
      }
    }
  },
  "servers": [
    {
      "url": "/api/pricing/v1"
    }
  ],
  "tags": [
    {
      "name": "Catalog"
    },
    {
      "name": "Service"
