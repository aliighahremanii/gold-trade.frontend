{
  "components": {
    "schemas": {
      "ProblemResponse": {
        "properties": {
          "code": {
            "type": "string"
          },
          "errors": {
            "items": {
              "$ref": "#/components/schemas/ProblemFieldError"
            },
            "type": "array"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "message"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "bearerFormat": "JWT",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "description": "Policy evaluation, limits, and manual review decisions for trading, payments, and delivery operations.",
    "title": "Compliance API",
    "version": "1.0.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/compliance/operations/{operation_type}/evaluate": {
      "post": {
        "operationId": "evaluateComplianceOperation",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "amount": {
                    "format": "int64",
                    "type": "integer"
                  },
                  "asset_code": {
                    "type": "string"
                  },
                  "business_reference": {
                    "type": "string"
                  },
                  "correlation_id": {
                    "type": "string"
                  },
                  "kyc_level": {
                    "type": "integer"
                  },
                  "market_symbol": {
                    "type": "string"
                  },
                  "user_id": {
                    "type": "string"
                  }
                },
                "required": [
                  "user_id",
                  "amount",
                  "kyc_level",
                  "correlation_id"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Compliance evaluation result"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Invalid request"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Persist an idempotent compliance evaluation for an operation",
        "tags": [
          "Compliance"
        ]
      }
    },
    "/compliance/policies/{operation_type}": {
      "get": {
        "operationId": "getCompliancePolicy",
        "responses": {
          "200": {
            "description": "Compliance policy"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required"
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Admin role required"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Policy not found"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Get compliance policy for an operation type",
        "tags": [
          "Policies"
        ]
      },
      "put": {
        "operationId": "upsertCompliancePolicy",
        "responses": {
          "200": {
            "description": "Compliance policy saved"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Invalid request"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required"
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Admin role required"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Create or update a compliance policy",
        "tags": [
          "Policies"
        ]
      }
    },
    "/compliance/review-cases": {
      "get": {
        "operationId": "listComplianceReviewCases",
        "responses": {
          "200": {
            "description": "Review case list"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required"
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Admin role required"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "List manual review cases",
        "tags": [
          "ReviewCases"
        ]
      }
    },
    "/compliance/review-cases/{id}": {
      "get": {
        "operationId": "getComplianceReviewCase",
        "responses": {
          "200": {
            "description": "Review case detail"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required"
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Admin role required"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Review case not found"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Get a manual review case",
        "tags": [
          "ReviewCases"
        ]
      }
    },
    "/compliance/review-cases/{id}/approve": {
      "post": {
        "operationId": "approveComplianceReviewCase",
        "responses": {
          "200": {
            "description": "Review case approved"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Invalid request"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required"
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Admin role required"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Review case not found"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Approve a pending manual review case",
        "tags": [
          "ReviewCases"
        ]
      }
    },
    "/compliance/review-cases/{id}/reject": {
      "post": {
        "operationId": "rejectComplianceReviewCase",
        "responses": {
          "200": {
            "description": "Review case rejected"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Invalid request"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required"
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Admin role required"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Review case not found"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Reject a pending manual review case",
        "tags": [
          "ReviewCases"
        ]
      }
    },
    "/health": {
      "get": {
        "operationId": "healthCheck",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "status": {
                      "example": "pong",
                      "type": "string"
                    }
                  },
                  "required": [
                    "status"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Service is healthy."
          }
        },
        "summary": "Service health check",
        "tags": [
          "Operations"
        ]
      }
    }
  },
  "servers": [
    {
      "url": "/api/compliance/v1"
    }
  ],
  "tags": [
    {
      "name": "Compliance"
    },
    {
      "name": "Policies"
    },
    {
      "name": "ReviewCases"
    }
  ]
}
