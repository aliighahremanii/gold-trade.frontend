{
  "components": {
    "schemas": {
      "CompleteDeliveryRequest": {
        "properties": {
          "handover_reference": {
            "type": "string"
          }
        },
        "required": [],
        "type": "object"
      },
      "CompleteWithdrawalRequest": {
