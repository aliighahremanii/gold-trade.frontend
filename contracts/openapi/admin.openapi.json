          },
          "reconciliation_reference": {
            "type": "string"
          }
        },
        "required": [
          "bank_transfer_reference"
        ],
        "type": "object"
      },
      "ConfirmDepositRequest": {
        "properties": {
          "bank_reference": {
            "type": "string"
          },
          "reconciliation_reference": {
            "type": "string"
          }
        },
        "required": [
          "bank_reference"
        ],
        "type": "object"
      },
      "DownstreamResponse": {
        "properties": {},
        "required": [],
        "type": "object"
      },
      "ProblemResponse": {
        "properties": {
          "code": {
            "type": "string"
          },
          "errors": {
            "items": {
              "$ref": "#/components/schemas/ProblemFieldError"
            },
            "type": "array"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "message"
        ],
        "type": "object"
      },
      "RejectDeliveryRequest": {
        "properties": {
          "reason": {
            "type": "string"
          }
        },
        "required": [],
        "type": "object"
      },
      "RejectWithdrawalRequest": {
        "properties": {
          "reason": {
            "type": "string"
          }
        },
        "required": [
          "reason"
        ],
        "type": "object"
      },
      "ScheduleDeliveryRequest": {
        "properties": {
          "scheduled_at": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "scheduled_at"
        ],
        "type": "object"
      },
      "SetManualPriceRequest": {
        "properties": {
          "buy_price": {
            "format": "int64",
            "type": "integer"
          },
          "effective_from": {
            "format": "date-time",
            "type": "string"
          },
          "expires_at": {
            "format": "date-time",
            "type": "string"
          },
          "quote_per_base_unit": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "sell_price": {
            "format": "int64",
            "type": "integer"
          }
        },
        "required": [
          "buy_price",
          "sell_price",
          "quote_per_base_unit"
        ],
        "type": "object"
      },
      "SetMarketExecutionStatusRequest": {
        "properties": {
          "provider_code": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ],
        "type": "object"
      },
      "SetMarketStatusRequest": {
        "properties": {
          "status": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ],
        "type": "object"
      },
      "SetProviderStatusRequest": {
        "properties": {
          "status": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "bearerFormat": "JWT",
        "scheme": "bearer",
        "type": "http"
      }
    }
