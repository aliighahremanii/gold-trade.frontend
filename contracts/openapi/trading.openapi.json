{
  "components": {
    "schemas": {
      "CreateOrderRequest": {
        "properties": {
          "idempotency_key": {
            "type": "string"
          },
          "quote_id": {
            "type": "string"
          }
        },
        "required": [
          "quote_id",
          "idempotency_key"
        ],
        "type": "object"
      },
      "OrderDetail": {
        "properties": {
          "approval_reason": {
            "type": "string"
          },
          "approved_at": {
            "format": "date-time",
            "type": "string"
          },
          "approved_by": {
            "type": "string"
          },
          "base_amount": {
            "format": "int64",
            "type": "integer"
          },
          "base_asset_code": {
            "type": "string"
          },
          "base_unit_code": {
            "type": "string"
          },
          "cancelled_at": {
            "format": "date-time",
            "type": "string"
          },
          "completed_at": {
            "format": "date-time",
            "type": "string"
          },
          "created_at": {
            "format": "date-time",
            "type": "string"
          },
          "execution_id": {
            "type": "string"
          },
          "failure_reason": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "idempotency_key": {
            "type": "string"
          },
          "market_symbol": {
            "type": "string"
          },
          "price_snapshot_id": {
            "type": "string"
          },
          "quote_asset_code": {
            "type": "string"
          },
          "quote_id": {
            "type": "string"
          },
          "side": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "total_quote_amount": {
            "format": "int64",
            "type": "integer"
          },
          "updated_at": {
            "format": "date-time",
            "type": "string"
          },
          "user_id": {
            "type": "string"
          },
          "wallet_lock_id": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "user_id",
          "quote_id",
          "idempotency_key",
          "market_symbol",
          "side",
          "status",
          "base_asset_code",
          "quote_asset_code",
          "base_amount",
          "base_unit_code",
          "total_quote_amount",
          "price_snapshot_id",
          "created_at",
          "updated_at"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "bearerFormat": "JWT",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "description": "Customer order lifecycle for market buy and sell on existing platform markets.",
    "title": "Trading API",
    "version": "1.0.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/health": {
      "get": {
        "operationId": "healthCheck",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "status": {
                      "example": "pong",
                      "type": "string"
                    }
                  },
                  "required": [
                    "status"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Service is healthy."
          }
        },
        "summary": "Service health check",
        "tags": [
          "Operations"
        ]
      }
    },
    "/orders": {
      "post": {
        "operationId": "createOrder",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrderRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderDetail"
                }
              }
            },
            "description": "Order created."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Invalid request body."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Quote not found."
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Quote not confirmed or order conflict."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Validation error."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Unexpected error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Create an order from a confirmed quote.",
        "tags": [
          "Orders"
        ]
      }
    },
    "/orders/{id}": {
      "get": {
        "operationId": "getOrder",
        "parameters": [
          {
            "description": "Order identifier.",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderDetail"
                }
              }
            },
            "description": "Order detail."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Order not found."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Unexpected error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Get an order by identifier.",
        "tags": [
          "Orders"
        ]
      }
    },
    "/orders/{id}/cancel": {
      "post": {
        "operationId": "cancelOrder",
        "parameters": [
          {
            "description": "Order identifier.",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderDetail"
                }
              }
            },
            "description": "Order cancelled."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Order not found."
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Order cannot be cancelled."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Unexpected error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Cancel a cancellable order and release wallet lock.",
        "tags": [
          "Orders"
        ]
      }
    },
    "/trading/admin/orders/{id}/approve": {
      "post": {
        "operationId": "approveOrder",
        "parameters": [
          {
            "description": "Order identifier.",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderDetail"
                }
              }
            },
            "description": "Order approved."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required."
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Admin role required."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Order not found."
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Order cannot be approved."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Unexpected error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Approve a manual-review order and request execution.",
        "tags": [
          "Admin"
        ]
      }
    }
  },
  "servers": [
    {
      "url": "/api/trading/v1"
    }
  ],
  "tags": [
    {
      "name": "Orders"
    },
    {
      "name": "Admin"
    }
  ]
}
