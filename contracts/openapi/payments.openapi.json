{
  "components": {
    "schemas": {
      "ApproveWithdrawalRequest": {
        "properties": {
          "approved_by": {
            "type": "string"
          }
        },
        "required": [
          "approved_by"
        ],
        "type": "object"
      },
      "CompleteWithdrawalRequest": {
        "properties": {
          "bank_transfer_reference": {
            "type": "string"
          },
          "reconciliation_reference": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "ConfirmDepositRequest": {
        "properties": {
          "bank_reference": {
            "type": "string"
          },
          "reconciliation_reference": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "DepositDetail": {
        "properties": {
          "amount": {
            "format": "int64",
            "type": "integer"
          },
          "bank_reference": {
            "type": "string"
          },
          "confirmed_at": {
            "format": "date-time",
            "nullable": true,
            "type": "string"
          },
          "created_at": {
            "format": "date-time",
            "type": "string"
          },
          "failure_reason": {
            "type": "string"
          },
          "gateway_provider": {
            "type": "string"
          },
          "gateway_reference": {
            "type": "string"
          },
          "gateway_tracking_code": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "idempotency_key": {
            "type": "string"
          },
          "payment_url": {
            "type": "string"
          },
          "reconciliation_reference": {
            "type": "string"
          },
          "settlement_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "updated_at": {
            "format": "date-time",
            "type": "string"
          },
          "user_id": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "idempotency_key",
          "user_id",
          "amount",
          "status",
          "gateway_provider",
          "created_at",
          "updated_at"
        ],
        "type": "object"
      },
      "GatewayCallbackRequest": {
        "properties": {
          "deposit_id": {
            "type": "string"
          },
          "idempotency_key": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "provider_reference": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        },
        "required": [
          "idempotency_key",
          "provider",
          "provider_reference",
          "status"
        ],
        "type": "object"
      },
      "RejectWithdrawalRequest": {
        "properties": {
          "reason": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "RequestDepositRequest": {
        "properties": {
          "amount": {
            "format": "int64",
            "type": "integer"
          },
          "idempotency_key": {
            "type": "string"
          }
        },
        "required": [
          "idempotency_key",
          "amount"
        ],
        "type": "object"
      },
      "RequestWithdrawalRequest": {
        "properties": {
          "amount": {
            "format": "int64",
            "type": "integer"
          },
          "bank_account_reference": {
            "type": "string"
          },
          "idempotency_key": {
            "type": "string"
          }
        },
        "required": [
          "idempotency_key",
          "amount",
          "bank_account_reference"
        ],
        "type": "object"
      },
      "WithdrawalDetail": {
        "properties": {
          "amount": {
            "format": "int64",
            "type": "integer"
          },
          "approved_by": {
            "type": "string"
          },
          "bank_account_reference": {
            "type": "string"
          },
          "bank_transfer_reference": {
            "type": "string"
          },
          "completed_at": {
            "format": "date-time",
            "nullable": true,
            "type": "string"
          },
          "created_at": {
            "format": "date-time",
            "type": "string"
          },
          "failure_reason": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "idempotency_key": {
            "type": "string"
          },
          "reconciliation_reference": {
            "type": "string"
          },
          "settlement_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "updated_at": {
            "format": "date-time",
            "type": "string"
          },
          "user_id": {
            "type": "string"
          },
          "wallet_lock_id": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "idempotency_key",
          "user_id",
          "amount",
          "status",
          "bank_account_reference",
          "created_at",
          "updated_at"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "bearerFormat": "JWT",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "description": "IRR deposit and withdrawal workflows with gateway callbacks, wallet locks, and settlement finalization.",
