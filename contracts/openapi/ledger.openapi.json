{
  "components": {
    "schemas": {
      "AccountBalance": {
        "properties": {
          "account_id": {
            "type": "string"
          },
          "asset_code": {
            "type": "string"
          },
          "balance": {
            "format": "int64",
            "type": "integer"
          }
        },
        "required": [
          "account_id",
          "asset_code",
          "balance"
        ],
        "type": "object"
      },
      "AccountDetail": {
        "properties": {
          "account_type": {
            "type": "string"
          },
          "asset_code": {
            "type": "string"
          },
          "created_at": {
            "format": "date-time",
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "owner_id": {
            "type": "string"
          },
          "owner_type": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "owner_type",
          "owner_id",
          "account_type",
          "asset_code",
          "status",
          "created_at"
        ],
        "type": "object"
      },
      "EntryDetail": {
        "properties": {
          "account_id": {
            "type": "string"
          },
          "amount": {
            "format": "int64",
            "type": "integer"
          },
          "asset_code": {
            "type": "string"
          },
          "direction": {
            "type": "string"
          },
          "id": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "account_id",
          "asset_code",
          "direction",
          "amount"
        ],
        "type": "object"
      },
      "OpenAccountRequest": {
        "properties": {
          "account_type": {
            "type": "string"
          },
          "asset_code": {
            "type": "string"
          },
          "owner_id": {
            "type": "string"
          },
          "owner_type": {
            "type": "string"
          }
        },
        "required": [
          "owner_type",
          "owner_id",
          "account_type",
          "asset_code"
        ],
        "type": "object"
      },
      "PostEntryRequest": {
        "properties": {
          "account_id": {
            "type": "string"
          },
          "amount": {
            "format": "int64",
            "type": "integer"
          },
          "direction": {
            "type": "string"
          }
        },
        "required": [
          "account_id",
          "direction",
          "amount"
        ],
        "type": "object"
      },
      "PostTransactionRequest": {
        "properties": {
          "description": {
            "type": "string"
          },
          "entries": {
            "items": {
              "$ref": "#/components/schemas/PostEntryRequest"
            },
            "type": "array"
          },
          "idempotency_key": {
            "type": "string"
          },
          "market_symbol": {
            "type": "string"
          },
          "source_module": {
            "type": "string"
          },
          "source_operation_id": {
            "type": "string"
          },
          "source_operation_type": {
            "type": "string"
          }
        },
        "required": [
          "idempotency_key",
          "description",
          "source_module",
          "source_operation_type",
          "source_operation_id",
          "entries"
        ],
        "type": "object"
      },
      "ProblemFieldError": {
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "message"
        ],
        "type": "object"
      },
      "ProblemResponse": {
        "properties": {
          "code": {
            "type": "string"
          },
          "errors": {
            "items": {
              "$ref": "#/components/schemas/ProblemFieldError"
            },
            "type": "array"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "message"
        ],
        "type": "object"
      },
      "ReverseTransactionRequest": {
        "properties": {
          "description": {
            "type": "string"
          },
          "idempotency_key": {
            "type": "string"
          },
          "source_module": {
            "type": "string"
          },
          "source_operation_id": {
            "type": "string"
          },
          "source_operation_type": {
            "type": "string"
          }
        },
        "required": [
          "idempotency_key",
          "description",
          "source_module",
          "source_operation_type",
          "source_operation_id"
        ],
        "type": "object"
      },
      "TransactionDetail": {
        "properties": {
          "description": {
            "type": "string"
          },
          "entries": {
            "items": {
              "$ref": "#/components/schemas/EntryDetail"
            },
            "type": "array"
          },
          "id": {
            "type": "string"
          },
          "idempotency_key": {
            "type": "string"
          },
          "market_symbol": {
            "type": "string"
          },
          "posted_at": {
            "format": "date-time",
            "type": "string"
          },
          "reverses_transaction_id": {
            "type": "string"
          },
          "source_module": {
            "type": "string"
          },
          "source_operation_id": {
            "type": "string"
          },
          "source_operation_type": {
            "type": "string"
          },
          "transaction_type": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "idempotency_key",
          "transaction_type",
          "description",
          "source_module",
          "source_operation_type",
          "source_operation_id",
          "entries",
          "posted_at"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "bearerFormat": "JWT",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "description": "Immutable double-entry accounting: ledger accounts, balanced idempotent postings, compensating reversals, and derived account balances.",
    "title": "Ledger API",
    "version": "1.0.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/health": {
      "get": {
        "operationId": "healthCheck",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "status": {
                      "example": "pong",
                      "type": "string"
                    }
                  },
                  "required": [
                    "status"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Service is healthy."
          }
        },
        "summary": "Service health check",
        "tags": [
          "Operations"
        ]
      }
    },
    "/ledger/accounts": {
      "get": {
        "operationId": "listLedgerAccountsByOwner",
        "parameters": [
          {
            "description": "Owner type.",
            "in": "query",
            "name": "owner_type",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Owner identifier.",
            "in": "query",
            "name": "owner_id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Filter by asset code.",
            "in": "query",
            "name": "asset_code",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/AccountDetail"
                  },
                  "type": "array"
                }
              }
            },
            "description": "Ledger accounts."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Unexpected error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "List ledger accounts for an owner.",
        "tags": [
          "Accounts"
        ]
      },
      "post": {
        "operationId": "openLedgerAccount",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OpenAccountRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountDetail"
                }
              }
            },
            "description": "Ledger account opened."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Invalid request body."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required."
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Ledger account already exists."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Validation error."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Unexpected error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Open a ledger account for an owner and asset.",
        "tags": [
          "Accounts"
        ]
      }
    },
    "/ledger/accounts/{id}": {
      "get": {
        "operationId": "getLedgerAccountByID",
        "parameters": [
          {
            "description": "Ledger account identifier.",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountDetail"
                }
              }
            },
            "description": "Ledger account detail."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Ledger account not found."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Unexpected error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Get a ledger account by identifier.",
        "tags": [
          "Accounts"
        ]
      }
    },
    "/ledger/accounts/{id}/balance": {
      "get": {
        "operationId": "getLedgerAccountBalance",
        "parameters": [
          {
            "description": "Ledger account identifier.",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountBalance"
                }
              }
            },
            "description": "Derived ledger account balance."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Ledger account not found."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Unexpected error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Get the derived balance for a ledger account.",
        "tags": [
          "Accounts"
        ]
      }
    },
    "/ledger/postings": {
      "post": {
        "operationId": "postLedgerTransaction",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PostTransactionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionDetail"
                }
              }
            },
            "description": "Ledger transaction posted."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Invalid request body."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Ledger account not found."
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Ledger transaction already exists."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Validation error."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Unexpected error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Post a balanced ledger transaction idempotently.",
        "tags": [
          "Postings"
        ]
      }
    },
    "/ledger/postings/{id}": {
      "get": {
        "operationId": "getLedgerTransactionByID",
        "parameters": [
          {
            "description": "Ledger transaction identifier.",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionDetail"
                }
              }
            },
            "description": "Ledger transaction detail."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Ledger transaction not found."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Unexpected error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Get a ledger transaction with entries.",
        "tags": [
          "Postings"
        ]
      }
    },
    "/ledger/postings/{id}/reverse": {
      "post": {
        "operationId": "reverseLedgerTransaction",
        "parameters": [
          {
            "description": "Ledger transaction identifier to reverse.",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReverseTransactionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionDetail"
                }
              }
            },
            "description": "Reversal transaction posted."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Invalid request body."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Ledger transaction not found."
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Reversal already exists."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Validation error."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Unexpected error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Post a compensating reversal for an existing transaction.",
        "tags": [
          "Postings"
        ]
      }
    }
  },
  "servers": [
    {
      "url": "/api/ledger/v1"
    }
  ],
  "tags": [
    {
      "name": "Accounts"
    },
    {
      "name": "Postings"
    }
  ]
}
