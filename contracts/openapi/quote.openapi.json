{
  "components": {
    "schemas": {
      "ConfirmationEligibility": {
        "properties": {
          "checked_at": {
            "format": "date-time",
            "type": "string"
          },
          "eligible": {
            "type": "boolean"
          },
          "expires_at": {
            "format": "date-time",
            "type": "string"
          },
          "quote_id": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        },
        "required": [
          "quote_id",
          "eligible",
          "status",
          "expires_at",
          "checked_at"
        ],
        "type": "object"
      },
      "CreateQuoteRequest": {
        "properties": {
          "display_amount": {
            "format": "int64",
            "type": "integer"
          },
          "display_unit": {
            "type": "string"
          },
          "market_symbol": {
            "type": "string"
          },
          "side": {
            "type": "string"
          }
        },
        "required": [
          "market_symbol",
          "side",
          "display_unit",
          "display_amount"
        ],
        "type": "object"
      },
      "QuoteDetail": {
        "properties": {
          "base_amount": {
            "format": "int64",
            "type": "integer"
          },
          "base_asset_code": {
            "type": "string"
          },
          "base_unit_code": {
            "type": "string"
          },
          "confirmed_at": {
            "format": "date-time",
            "type": "string"
          },
          "created_at": {
            "format": "date-time",
            "type": "string"
          },
          "display_amount": {
            "format": "int64",
            "type": "integer"
          },
          "display_unit": {
            "type": "string"
          },
          "expires_at": {
            "format": "date-time",
            "type": "string"
          },
          "fee_amount": {
            "format": "int64",
            "type": "integer"
          },
          "gross_quote_amount": {
            "format": "int64",
            "type": "integer"
          },
          "id": {
            "type": "string"
          },
          "market_symbol": {
            "type": "string"
          },
          "price_snapshot_id": {
            "type": "string"
          },
          "price_source": {
            "type": "string"
          },
          "quote_asset_code": {
            "type": "string"
          },
          "quote_per_base_unit": {
            "type": "string"
          },
          "side": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "total_quote_amount": {
            "format": "int64",
            "type": "integer"
          },
          "unit_price": {
            "format": "int64",
            "type": "integer"
          },
          "user_id": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "user_id",
          "market_symbol",
          "side",
          "status",
          "base_asset_code",
          "quote_asset_code",
          "base_amount",
          "base_unit_code",
          "display_unit",
          "display_amount",
          "unit_price",
          "quote_per_base_unit",
          "gross_quote_amount",
          "fee_amount",
          "total_quote_amount",
          "price_snapshot_id",
          "price_source",
          "expires_at",
          "created_at"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "bearerFormat": "JWT",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "description": "Time-limited, confirmable buy/sell quotes for existing platform markets.",
    "title": "Quote API",
    "version": "1.0.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/health": {
      "get": {
        "operationId": "healthCheck",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "status": {
                      "example": "pong",
                      "type": "string"
                    }
                  },
                  "required": [
                    "status"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Service is healthy."
          }
        },
        "summary": "Service health check",
        "tags": [
          "Operations"
        ]
      }
    },
    "/quote/quotes/{id}": {
      "get": {
        "operationId": "getQuoteForService",
        "parameters": [
          {
            "description": "Quote identifier.",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuoteDetail"
                }
              }
            },
            "description": "Quote detail."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Quote not found."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Unexpected error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Get a quote for downstream validation.",
        "tags": [
          "Service"
        ]
      }
    },
    "/quote/quotes/{id}/confirm": {
      "post": {
        "operationId": "confirmQuote",
        "parameters": [
          {
            "description": "Quote identifier.",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuoteDetail"
                }
              }
            },
            "description": "Confirmed quote."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Quote not found."
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Quote expired or not confirmable."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Unexpected error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Confirm a pending quote before order creation.",
        "tags": [
          "Service"
        ]
      }
    },
    "/quote/quotes/{id}/confirmation-eligibility": {
      "get": {
        "operationId": "checkQuoteConfirmationEligibilityForService",
        "parameters": [
          {
            "description": "Quote identifier.",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfirmationEligibility"
                }
              }
            },
            "description": "Confirmation eligibility."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Quote not found."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Unexpected error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Check quote confirmation eligibility for downstream modules.",
        "tags": [
          "Service"
        ]
      }
    },
    "/quote/quotes/{id}/consume": {
      "post": {
        "operationId": "consumeQuote",
        "parameters": [
          {
            "description": "Quote identifier.",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuoteDetail"
                }
              }
            },
            "description": "Consumed quote."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Quote not found."
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Quote not confirmed or already consumed."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Unexpected error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Mark a confirmed quote as consumed before order creation.",
        "tags": [
          "Service"
        ]
      }
    },
