          "base_unit_code": {
            "type": "string"
          },
          "buy_enabled": {
            "type": "boolean"
          },
          "market_symbol": {
            "type": "string"
          },
          "max_base_amount": {
            "format": "int64",
            "type": "integer"
          },
          "min_base_amount": {
            "format": "int64",
            "type": "integer"
          },
          "provider_code": {
            "type": "string"
          },
          "provider_symbol": {
            "type": "string"
          },
          "sell_enabled": {
            "type": "boolean"
          },
          "updated_at": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "provider_code",
          "market_symbol",
          "provider_symbol",
          "buy_enabled",
          "sell_enabled",
          "base_unit_code",
          "updated_at"
        ],
        "type": "object"
      },
      "ProviderDetail": {
        "properties": {
          "code": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "updated_at": {
            "format": "date-time",
            "type": "string"
          },
          "updated_by": {
            "type": "string"
          },
          "venue_type": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "name",
          "venue_type",
          "status",
          "updated_at"
        ],
        "type": "object"
      },
      "RequestExecutionRequest": {
        "properties": {
          "base_amount": {
            "format": "int64",
            "type": "integer"
          },
          "base_unit_code": {
            "type": "string"
          },
          "correlation_id": {
            "type": "string"
          },
          "idempotency_key": {
            "type": "string"
          },
          "market_symbol": {
            "type": "string"
          },
          "provider_code": {
            "type": "string"
          },
