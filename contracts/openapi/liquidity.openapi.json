          },
          {
            "description": "Execution side.",
            "in": "query",
            "name": "side",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Base amount to validate.",
            "in": "query",
            "name": "base_amount",
            "required": false,
            "schema": {
              "type": "string"
