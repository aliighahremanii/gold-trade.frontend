        "required": [
          "correlation_id",
          "idempotency_key",
          "market_symbol",
          "side",
          "base_amount"
        ],
        "type": "object"
      },
      "SetMarketExecutionStatusRequest": {
        "properties": {
          "actor_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        },
        "required": [
          "status",
          "actor_id"
        ],
        "type": "object"
      },
      "SetProviderStatusRequest": {
        "properties": {
          "actor_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        },
        "required": [
          "status",
          "actor_id"
        ],
        "type": "object"
      },
      "UpsertMarketMappingRequest": {
        "properties": {
          "base_unit_code": {
            "type": "string"
          },
          "buy_enabled": {
            "type": "boolean"
          },
          "max_base_amount": {
            "format": "int64",
            "type": "integer"
          },
          "min_base_amount": {
            "format": "int64",
            "type": "integer"
          },
          "provider_symbol": {
            "type": "string"
          },
          "sell_enabled": {
            "type": "boolean"
