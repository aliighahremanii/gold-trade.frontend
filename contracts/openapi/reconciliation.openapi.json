            "type": "integer"
          },
          "internal_bank_reference": {
            "type": "string"
          },
          "internal_id": {
            "type": "string"
          },
          "internal_reconciliation_reference": {
            "type": "string"
          },
          "internal_status": {
            "type": "string"
          },
          "payment_type": {
            "example": "deposit",
