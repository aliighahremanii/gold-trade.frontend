            "type": "string"
          },
          "created_at": {
            "format": "date-time",
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "expected_value": {
            "type": "string"
          },
          "external_ref_id": {
            "type": "string"
          },
          "external_ref_type": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "internal_ref_id": {
            "type": "string"
          },
          "internal_ref_type": {
            "type": "string"
          },
          "market_symbol": {
            "type": "string"
          },
          "mismatch_type": {
            "type": "string"
          },
          "provider_code": {
            "type": "string"
          },
          "provider_symbol": {
            "type": "string"
          },
          "resolution_notes": {
            "type": "string"
          },
          "resolved_at": {
            "format": "date-time",
            "type": "string"
          },
          "run_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "updated_at": {
            "format": "date-time",
