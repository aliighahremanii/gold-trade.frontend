  "info": {
    "description": "Compares internal records with external provider, bank, custody, and ledger views. Detects mismatches and records exceptions without mutating financial state.",
    "title": "Reconciliation API",
    "version": "1.0.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/health": {
      "get": {
        "operationId": "healthCheck",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "status": {
                      "example": "pong",
                      "type": "string"
                    }
                  },
                  "required": [
                    "status"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Service is healthy."
          }
        },
        "summary": "Service health check",
        "tags": [
          "Operations"
        ]
      }
    },
    "/reconciliation/mismatches": {
      "get": {
        "operationId": "listMismatches",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/MismatchDetail"
                  },
                  "type": "array"
                }
              }
            },
            "description": "Reconciliation mismatches."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Unexpected error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "List reconciliation mismatches.",
        "tags": [
          "Service"
        ]
      }
    },
