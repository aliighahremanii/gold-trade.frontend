{
  "components": {
    "schemas": {
      "ProblemResponse": {
        "properties": {
          "code": {
            "type": "string"
          },
          "errors": {
            "items": {
              "$ref": "#/components/schemas/ProblemFieldError"
            },
            "type": "array"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "message"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "bearerFormat": "JWT",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "description": "Immutable audit trail for sensitive business actions: actor, action, target, reason, and business references.",
    "title": "Audit API",
    "version": "1.0.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/audit/records": {
      "get": {
        "operationId": "listAuditRecords",
        "responses": {
          "200": {
            "description": "Audit record list"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required"
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Admin role required"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "List audit records for compliance review",
        "tags": [
          "Audit"
        ]
      },
      "post": {
        "operationId": "appendAuditRecord",
        "responses": {
          "200": {
            "description": "Duplicate idempotency key"
          },
          "201": {
            "description": "Audit record created"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Invalid request"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Append an immutable audit record",
        "tags": [
          "Audit"
        ]
      }
    },
    "/audit/records/{id}": {
      "get": {
        "operationId": "getAuditRecord",
        "responses": {
          "200": {
            "description": "Audit record detail"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Authentication required"
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Admin role required"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemResponse"
                }
              }
            },
            "description": "Audit record not found"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Get an audit record by id",
        "tags": [
          "Audit"
        ]
      }
    },
    "/health": {
      "get": {
        "operationId": "healthCheck",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "status": {
                      "example": "pong",
                      "type": "string"
                    }
                  },
                  "required": [
                    "status"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Service is healthy."
          }
        },
        "summary": "Service health check",
        "tags": [
          "Operations"
        ]
      }
    }
  },
  "servers": [
    {
      "url": "/api/audit/v1"
    }
  ],
  "tags": [
    {
      "name": "Audit"
    }
  ]
}
